# ── Serveur ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Auth JWT ─────────────────────────────────────────────────────────────────
# Générer : node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=CHANGE_ME_32_BYTES_HEX
JWT_REFRESH_SECRET=CHANGE_ME_32_BYTES_HEX
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=5d

# ── Chiffrement tokens Strava (AES-256) ──────────────────────────────────────
# Générer : node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=CHANGE_ME_64_CHARS_HEX

# ── Base de données ───────────────────────────────────────────────────────────
# Railway injecte automatiquement MYSQL_URL — ne pas renseigner manuellement
# MYSQL_URL=mysql://user:pass@host:port/db

# En local uniquement :
# DB_HOST=localhost
# DB_PORT=8889
# DB_NAME=fit
# DB_USER=root
# DB_PASS=root

# ── Strava OAuth ──────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=https://your-server.railway.app/api/strava/callback
# Générer : node -e "require('crypto').randomBytes(16).toString('hex')"
STRAVA_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_RANDOM_STRING
FRONTEND_URL=https://your-client.railway.app

# ── IA Coach ──────────────────────────────────────────────────────────────────
# Mode LOCAL (dev) :
# MISTRAL_API_URL=http://localhost:11434/v1/chat/completions
# MISTRAL_API_KEY=ollama
# MISTRAL_MODEL=llama3.2:latest

# Mode CLOUD (prod) :
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_TOKENS=768
