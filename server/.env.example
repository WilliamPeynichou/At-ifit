# JWT
JWT_SECRET=your-super-secret-jwt-key-32-chars-minimum
JWT_EXPIRE=7d

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:5174

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=at_ifit

# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback

# Mistral AI — mode LOCAL avec Ollama (recommandé pour dev)
MISTRAL_API_URL=http://localhost:11434/v1/chat/completions
MISTRAL_API_KEY=ollama
MISTRAL_MODEL=ministral:8b

# Mistral AI — mode CLOUD (commenter les 3 lignes ci-dessus et décommenter ci-dessous)
# MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
# MISTRAL_API_KEY=your_mistral_api_key
# MISTRAL_MODEL=mistral-large-latest
